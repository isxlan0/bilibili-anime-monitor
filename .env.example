WEB_HOST=127.0.0.1
WEB_PORT=8688

DB_PATH=data/app.db
POLL_INTERVAL_SECONDS=1800
HTTP_TIMEOUT_SECONDS=20
TELEGRAM_POLL_TIMEOUT_SECONDS=2
